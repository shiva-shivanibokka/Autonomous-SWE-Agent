# Lightweight serving image for Fly.io — metadata + benchmark endpoints only.
# Excludes the Docker sandbox, embedding search, and eval stack (PyTorch/swebench),
# so the image stays small. Live agent runs happen locally, not here.
FROM python:3.11-slim

WORKDIR /app

# Serving deps only (no PyTorch) — better layer caching.
COPY requirements-serve.txt .
RUN pip install --no-cache-dir -r requirements-serve.txt

# Install the local package without pulling the heavy extras.
COPY . .
RUN pip install --no-cache-dir -e . --no-deps

EXPOSE 8000
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
