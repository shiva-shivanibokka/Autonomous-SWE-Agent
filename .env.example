# ── LLM (BYOK) ───────────────────────────────────────────────────────────────
# The API/UI is bring-your-own-key: keys arrive per request, none are stored
# server-side. These per-provider vars are ONLY used by local eval runs
# (python -m eval.run_eval --provider <p>). Set the one(s) you'll evaluate with.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token with repo + pull_request scopes
GITHUB_TOKEN=

# ── Runtime ──────────────────────────────────────────────────────────────────
# Live agent runs need a Docker sandbox. Keep false on PaaS without Docker
# (Render/Vercel); docker-compose sets this to true automatically.
ENABLE_LIVE_RUNS=false
# Deployed frontend origin for CORS (e.g. https://your-app.vercel.app). "*" = dev.
FRONTEND_ORIGIN=*
# Public URL this API is reached on, e.g. https://your-api.onrender.com.
# Used to hand the browser a wss:// URL behind TLS. Blank = local ws://.
PUBLIC_BASE_URL=

# ── Evaluation ───────────────────────────────────────────────────────────────
# Number of SWE-bench-lite instances to evaluate (max 300)
EVAL_INSTANCE_LIMIT=300
# Max parallel workers for evaluation (1 = sequential, safe for free-tier Docker)
EVAL_MAX_WORKERS=4
# Max turns per agent task before giving up
AGENT_MAX_TURNS=50
# Context budget: stop agent before hitting model limit (claude = 200k tokens)
AGENT_CONTEXT_BUDGET=150000

# ── Agentless ────────────────────────────────────────────────────────────────
# Number of repair patches to sample per localized location
AGENTLESS_NUM_SAMPLES=10

# ── Docker sandbox ───────────────────────────────────────────────────────────
# Memory limit per sandbox container
SANDBOX_MEMORY_LIMIT=2g
# CPU limit per sandbox container
SANDBOX_CPU_LIMIT=2.0
# Seconds before a bash command times out inside the sandbox
SANDBOX_CMD_TIMEOUT=120

# ── Observability ────────────────────────────────────────────────────────────
# OTLP endpoint for Jaeger (traces)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Prometheus metrics port
PROMETHEUS_PORT=9090

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── UI ────────────────────────────────────────────────────────────────────────
UI_PORT=7860
